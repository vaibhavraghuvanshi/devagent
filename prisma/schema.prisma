// Auth.js / NextAuth models + DevAgent chat persistence + user settings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- NextAuth / Auth.js (required by @auth/prisma-adapter) ---

enum Theme {
  SYSTEM
  DARK
  LIGHT
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  password      String?          // hashed, null for OAuth-only users
  accounts      Account[]
  sessions      Session[]
  chatSessions  ChatSession[]
  sharedChats   SharedChat[]
  profile       UserProfile?
  preferences   UserPreferences?
  appearance    UserAppearance?
  dataPrivacy   UserDataPrivacy?
  security      UserSecurity?
  integrations  UserIntegrations?
  billing       UserBilling?
  notifications UserNotifications?
  advanced      UserAdvanced?
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?  @db.Text
  language  String   @default("English")
  timezone  String   @default("(GMT+05:30) Asia/Kolkata")
  avatarUrl String?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreferences {
  id               String   @id @default(cuid())
  userId           String   @unique
  defaultModel     String   @default("claude-sonnet-4-6")
  defaultMode      String   @default("chat")
  sendOnEnter      Boolean  @default(true)
  codeHighlighting Boolean  @default(true)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAppearance {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     Theme    @default(SYSTEM)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDataPrivacy {
  id                String   @id @default(cuid())
  userId            String   @unique
  saveHistory       Boolean  @default(true)
  analyticsEnabled  Boolean  @default(true)
  dataRetentionDays Int      @default(90)
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSecurity {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  twoFactorEnabled          Boolean  @default(false)
  loginAlerts               Boolean  @default(true)
  suspiciousSignInDetection Boolean  @default(true)
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserIntegrations {
  id                  String   @id @default(cuid())
  userId              String   @unique
  githubConnected     Boolean  @default(false)
  slackConnected      Boolean  @default(false)
  jiraConnected       Boolean  @default(false)
  linearConnected     Boolean  @default(false)
  webhookUrl          String?
  syncIntervalMinutes Int      @default(15)
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBilling {
  id             String   @id @default(cuid())
  userId         String   @unique
  plan           String   @default("free")
  billingCycle   String   @default("monthly")
  autoRenew      Boolean  @default(false)
  usageAlerts    Boolean  @default(true)
  spendLimitUsd  Int      @default(0)
  invoiceEmail   String?
  taxId          String?
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserNotifications {
  id                String   @id @default(cuid())
  userId            String   @unique
  emailNotifications Boolean  @default(true)
  pushNotifications Boolean  @default(false)
  productUpdates    Boolean  @default(true)
  securityAlerts    Boolean  @default(true)
  weeklySummary     Boolean  @default(true)
  quietHoursStart   String   @default("22:00")
  quietHoursEnd     String   @default("07:00")
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAdvanced {
  id               String   @id @default(cuid())
  userId           String   @unique
  developerMode    Boolean  @default(false)
  betaFeatures     Boolean  @default(false)
  streamResponses  Boolean  @default(true)
  verboseToolLogs  Boolean  @default(false)
  safeMode         Boolean  @default(true)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- DevAgent chat (distinct from Auth "Session" above) ---

enum ChatRole {
  USER
  ASSISTANT
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New chat")
  mode      String   @default("chat") // "chat" | "agent"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  contextFiles ContextFile[]
  sharedChats  SharedChat[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id            String    @id @default(cuid())
  chatSessionId String
  role          ChatRole
  content       String    @db.Text
  modelId       String?
  createdAt     DateTime  @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  toolCalls   ToolCall[]

  @@index([chatSessionId, createdAt])
}

model ToolCall {
  id         String   @id @default(cuid())
  messageId  String
  externalId String?
  name       String
  args       Json
  result     String?  @db.Text
  createdAt  DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ContextFile {
  id            String   @id @default(cuid())
  chatSessionId String
  path          String
  addedAt       DateTime @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@unique([chatSessionId, path])
}

model SharedChat {
  id            String      @id @default(cuid())
  shareToken    String      @unique
  chatSessionId String
  userId        String
  createdAt     DateTime    @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
}
